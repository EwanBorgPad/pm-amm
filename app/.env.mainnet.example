# pm-AMM front — MAINNET-BETA configuration.
# Copy these into your Vercel project (Production environment). This file is a
# template only — it contains NO secrets and is safe to commit.

# Cluster selector — flips the app to mainnet (disables the faucet, drops the
# ?cluster= query on Solscan links, picks the mainnet RPC fallback).
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# Program ID — same as devnet (declare_id! is compiled in; clusters are isolated).
NEXT_PUBLIC_PROGRAM_ID=GV1FMGHRYBjQLaghE5fnGuYCuCcpdt3GD5xEX3TwN16y

# Real USDC (Circle, 6 decimals).
NEXT_PUBLIC_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Mainnet RPC — use a DEDICATED provider (Helius / Triton / QuickNode). The
# public endpoint (api.mainnet-beta.solana.com) is rate-limited and will break
# the app under any real traffic.
NEXT_PUBLIC_RPC_URL=https://your-mainnet-rpc-endpoint-here

# IMPORTANT: do NOT set MINT_AUTHORITY_KEY on mainnet. The faucet is disabled
# (real USDC is not mintable) — leaving it unset is correct and intentional.
